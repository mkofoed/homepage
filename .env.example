# ⚠️  THIS IS AN EXAMPLE FILE — DO NOT USE THESE VALUES IN PRODUCTION
# Copy to .env and replace ALL placeholder values with real secrets.

DEBUG=0
SECRET_KEY=change-me-to-a-long-random-string
DJANGO_ALLOWED_HOSTS=mkofoed.dev,www.mkofoed.dev

# Database — use a dedicated app user, NOT the postgres superuser
SQL_ENGINE=django.db.backends.postgresql
SQL_DATABASE=homepage
SQL_USER=homepage_app
SQL_PASSWORD=change-me-to-a-strong-password
SQL_HOST=db
SQL_PORT=5432
DATABASE=postgres

# These must match docker-compose.prod.yml db service
POSTGRES_USER=homepage_app
POSTGRES_PASSWORD=change-me-to-a-strong-password
POSTGRES_DB=homepage

SENTRY_DSN=

# Redis — password must match REDIS_PASSWORD
# REDIS_PASSWORD placeholder removed as it is redefined above for clarity
REDIS_PASSWORD=
# Change this to your Redis password or leave empty for no authentication
