# Normalize all text files to LF on checkout
* text=auto eol=lf

# Explicitly declare text files
*.py text eol=lf
*.html text eol=lf
*.css text eol=lf
*.js text eol=lf
*.json text eol=lf
*.md text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.txt text eol=lf
*.conf text eol=lf
*.sh text eol=lf
*.env text eol=lf
Dockerfile text eol=lf
Dockerfile.* text eol=lf
.dockerignore text eol=lf
.gitignore text eol=lf

# Binary files - never modify
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
